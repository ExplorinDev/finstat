generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id          Int       @id @default(autoincrement())
  ico         String    @unique
  name        String
  address     String
  city        String
  region      String?
  district    String?
  legalForm   String?
  dateCreated DateTime?
  dateDeleted DateTime?
  status      String?
  cachedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  statutoryMembers StatutoryMember[]
  shareholders     Shareholder[]
}

model StatutoryMember {
  id          Int       @id @default(autoincrement())
  companyIco  String
  company     Company   @relation(fields: [companyIco], references: [ico])
  firstName   String?
  lastName    String?
  titleBefore String?
  titleAfter  String?
  role        String?
  dateFrom    DateTime?
  dateTo      DateTime?

  @@index([companyIco])
}

model Shareholder {
  id             Int       @id @default(autoincrement())
  companyIco     String
  company        Company   @relation(fields: [companyIco], references: [ico])
  firstName      String?
  lastName       String?
  companyName    String?
  shareholderIco String?
  shareText      String?
  dateFrom       DateTime?
  dateTo         DateTime?

  @@index([companyIco])
}
